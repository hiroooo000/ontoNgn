{
  "nodes": [
    {
      "id": "ap:proc_mental_handbook_apply",
      "label": "精神障害者保健手帳の申請・更新・等級変更",
      "properties": {
        "type": "ap:Procedure",
        "description": "精神障害のある方が手帳の申請、更新、等級変更を行う手続き"
      }
    },
    {
      "id": "ap:actor_person_with_mental_disability",
      "label": "精神障害のある方",
      "properties": {
        "type": "ap:Actor",
        "description": "長期にわたり日常生活又は社会生活への制約がある方。統合失調症、気分障害、てんかん、依存症、高次脳機能障害、発達障害などが対象"
      }
    },
    {
      "id": "ap:org_disability_welfare_section",
      "label": "障害福祉課知的障害者支援係",
      "properties": {
        "type": "ap:Organization",
        "description": "問い合わせ先"
      }
    },
    {
      "id": "ap:doc_handbook",
      "label": "精神障害者保健手帳",
      "properties": {
        "type": "ap:Document",
        "description": "障害の程度を証明するもので、等級(1～3級)に応じた支援を受けられる"
      }
    },
    {
      "id": "ap:doc_medical_cert",
      "label": "手帳診断書又は精神障害者年金診断書のコピー",
      "properties": {
        "type": "ap:Document",
        "description": "申請時に必要。初診日から6か月を経過した日以降作成のもの"
      }
    },
    {
      "id": "ap:doc_photo",
      "label": "写真",
      "properties": {
        "type": "ap:Document",
        "description": "縦4cm×横3cm、上半身、1年以内に撮影したもの1枚"
      }
    },
    {
      "id": "ap:doc_my_number_card",
      "label": "マイナンバーカード又は通帳カード",
      "properties": {
        "type": "ap:Document",
        "description": "申請時に必要"
      }
    },
    {
      "id": "ap:doc_id",
      "label": "身分証明書",
      "properties": {
        "type": "ap:Document",
        "description": "マイナンバーカードを持参の場合は不要"
      }
    },
    {
      "id": "ap:doc_current_handbook",
      "label": "現在お持ちの手帳",
      "properties": {
        "type": "ap:Document",
        "description": "更新の場合に必要"
      }
    },
    {
      "id": "ap:doc_postcard",
      "label": "氏名を記入したはがき",
      "properties": {
        "type": "ap:Document",
        "description": "手帳交付の通知を希望する場合に必要"
      }
    },
    {
      "id": "ap:cond_long_term_restriction",
      "label": "長期の日常生活又は社会生活への制約",
      "properties": {
        "type": "ap:Condition",
        "description": "対象となる方の条件"
      }
    },
    {
      "id": "ap:cond_6_months_passed",
      "label": "初診日から6か月経過",
      "properties": {
        "type": "ap:Condition",
        "description": "診断書作成の条件"
      }
    },
    {
      "id": "ap:cond_3_months_apply",
      "label": "診断書作成から3か月以内の申請",
      "properties": {
        "type": "ap:Condition",
        "description": "申請期限の条件"
      }
    },
    {
      "id": "ap:cond_validity_2_years",
